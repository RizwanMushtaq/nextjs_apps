        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^20.19.41",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "dotenv": "^17.4.2",
        "eslint": "^9",
        "eslint-config-next": "16.2.6",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.3",
